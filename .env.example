# Copy this file to .env and fill in real values.
# The server reads these from the environment (e.g. via `dotenv`, your shell,
# or your hosting provider's environment variable settings).

# PostgreSQL connection string (required)
DATABASE_URL=postgres://user:password@localhost:5432/imarat_e_shariah

# Password for the admin dashboard at /admin (recommended to set explicitly)
ADMIN_PASSWORD=change-me

# Port the API server listens on (optional, defaults to 5000)
PORT=5000

# Log verbosity: trace | debug | info | warn | error | fatal (optional, defaults to info)
LOG_LEVEL=info

# development | production (optional, defaults to development)
NODE_ENV=development
